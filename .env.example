APP_NAME="Parental Control API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost:8000
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=parental_control
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Laravel Reverb (WebSockets الرسمي)
REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Google Maps & Firebase
GOOGLE_MAPS_API_KEY=
FCM_SERVER_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# Parental Control Settings
LOCATION_UPDATE_INTERVAL=900
COMMAND_CHECK_INTERVAL=60
COMMAND_EXPIRATION=3600
COMMAND_MAX_RETRIES=3

MAX_HISTORY_DAYS=90
SCREENSHOT_QUALITY=80
ENABLE_CALL_RECORDING=false
ENABLE_SMS_MONITORING=true

FREE_PLAN_DEVICES=2
PREMIUM_PLAN_DEVICES=5
FAMILY_PLAN_DEVICES=10

# Security
ENCRYPT_SENSITIVE_DATA=true
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Cache TTL (seconds)
CACHE_USER_TTL=300
CACHE_DEVICE_TTL=600
CACHE_SETTINGS_TTL=900

# Telescope (Development only)
TELESCOPE_ENABLED=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

VITE_APP_NAME="${APP_NAME}"
